@page "/tasks"
@attribute [Authorize]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Tasks</PageTitle>

<MudStack Spacing="4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4">Work items</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddTask" OnClick="StartCreate">
            Add task
        </MudButton>
    </MudStack>

    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End" Justify="Justify.FlexStart">
            <MudSelect T="string" @bind-Value="_filterState" Label="State" Variant="Variant.Outlined" Style="min-width:200px;">
                <MudSelectItem Value="@string.Empty">All</MudSelectItem>
                @foreach (var s in _states)
                {
                    <MudSelectItem Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Outlined" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    @if (_editing is not null)
    {
        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-3">@(_editing.Id == 0 ? "New task" : "Edit task")</MudText>
            <EditForm Model="_editing" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_editing.Title" For="@(() => _editing.Title)" Label="Title" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker @bind-Date="_dueDate" Label="Due date" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_editing.Description" For="@(() => _editing.Description)" Label="Description" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int" @bind-Value="_editing.ProjectId" Label="Project" Variant="Variant.Outlined">
                            @foreach (var p in _projectList)
                            {
                                <MudSelectItem Value="@p.Id">@p.Code — @p.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="int?" @bind-Value="_editing.AssigneeId" Label="Assignee" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var e in _employeeList)
                            {
                                <MudSelectItem T="int?" Value="@e.Id">@e.FullName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" @bind-Value="_editing.Priority" Label="Priority" Variant="Variant.Outlined">
                            @foreach (var p in _priorities)
                            {
                                <MudSelectItem Value="@p">@p</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" @bind-Value="_editing.State" Label="State" Variant="Variant.Outlined">
                            @foreach (var s in _states)
                            {
                                <MudSelectItem Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" Class="d-flex gap-2">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Save</MudButton>
                        <MudButton Variant="Variant.Text" OnClick="CancelEdit">Cancel</MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    }

    <MudPaper Elevation="0" Outlined="true">
        <MudTable Items="_rows" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true" Loading="_loading">
            <HeaderContent>
                <MudTh>Task</MudTh>
                <MudTh>Project</MudTh>
                <MudTh>Assignee</MudTh>
                <MudTh>Priority</MudTh>
                <MudTh>State</MudTh>
                <MudTh>Due</MudTh>
                <MudTh Style="width:120px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Task">
                    <MudText Typo="Typo.body2"><strong>@context.Title</strong></MudText>
                    @if (!string.IsNullOrWhiteSpace(context.Description))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@Truncate(context.Description, 90)</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Project">@context.Project?.Code</MudTd>
                <MudTd DataLabel="Assignee">@context.Assignee?.FullName</MudTd>
                <MudTd DataLabel="Priority">@context.Priority</MudTd>
                <MudTd DataLabel="State">@context.State</MudTd>
                <MudTd DataLabel="Due">@context.DueDate.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" OnClick="@(() => StartEdit(context.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" OnClick="@(() => DeleteAsync(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private readonly List<WorkItem> _rows = new();
    private List<Project> _projectList = new();
    private List<Employee> _employeeList = new();
    private WorkItem? _editing;
    private DateTime? _dueDate;
    private string _filterState = string.Empty;
    private readonly string[] _states = ["New", "Active", "Done"];
    private readonly string[] _priorities = ["Low", "Medium", "High"];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _projectList = await Db.Projects.AsNoTracking().OrderBy(p => p.Code).ToListAsync();
        _employeeList = await Db.Employees.AsNoTracking().OrderBy(e => e.FullName).ToListAsync();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        var q = Db.WorkItems.AsNoTracking().Include(w => w.Project).Include(w => w.Assignee).AsQueryable();
        if (!string.IsNullOrEmpty(_filterState))
            q = q.Where(w => w.State == _filterState);

        _rows.Clear();
        _rows.AddRange(await q.OrderBy(w => w.DueDate).ToListAsync());
        _loading = false;
    }

    private async Task ApplyFilter()
    {
        await ReloadAsync();
    }

    private void StartCreate()
    {
        _editing = new WorkItem
        {
            ProjectId = _projectList.FirstOrDefault()?.Id ?? 0,
            Priority = "Medium",
            State = "New",
            DueDate = DateTime.UtcNow.Date.AddDays(7)
        };
        _dueDate = _editing.DueDate;
    }

    private async Task StartEdit(int id)
    {
        var entity = await Db.WorkItems.FirstOrDefaultAsync(w => w.Id == id);
        if (entity is null)
            return;
        _editing = new WorkItem
        {
            Id = entity.Id,
            ProjectId = entity.ProjectId,
            AssigneeId = entity.AssigneeId,
            Title = entity.Title,
            Description = entity.Description,
            Priority = entity.Priority,
            State = entity.State,
            DueDate = entity.DueDate
        };
        _dueDate = entity.DueDate;
    }

    private void CancelEdit()
    {
        _editing = null;
        _dueDate = null;
    }

    private async Task SaveAsync()
    {
        if (_editing is null)
            return;
        if (_dueDate is not null)
            _editing.DueDate = DateTime.SpecifyKind(_dueDate.Value.Date, DateTimeKind.Utc);

        if (_editing.Id == 0)
        {
            Db.WorkItems.Add(_editing);
        }
        else
        {
            var tracked = await Db.WorkItems.FirstAsync(w => w.Id == _editing.Id);
            tracked.ProjectId = _editing.ProjectId;
            tracked.AssigneeId = _editing.AssigneeId;
            tracked.Title = _editing.Title;
            tracked.Description = _editing.Description;
            tracked.Priority = _editing.Priority;
            tracked.State = _editing.State;
            tracked.DueDate = _editing.DueDate;
        }

        await Db.SaveChangesAsync();
        Snackbar.Add("Task saved", Severity.Success);
        CancelEdit();
        await ReloadAsync();
    }

    private async Task DeleteAsync(WorkItem row)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Remove “{row.Title}”?");
        if (!ok)
            return;

        var tracked = await Db.WorkItems.FirstOrDefaultAsync(w => w.Id == row.Id);
        if (tracked is null)
            return;

        Db.WorkItems.Remove(tracked);
        await Db.SaveChangesAsync();
        Snackbar.Add("Task removed", Severity.Info);
        await ReloadAsync();
    }

    private static string Truncate(string text, int max)
    {
        if (text.Length <= max)
            return text;
        return text[..(max - 1)] + "…";
    }
}
