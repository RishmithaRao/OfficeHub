@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" DefaultScrollbar="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-2">OfficeHub</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2 d-none d-sm-block">@context.User.Identity?.Name</MudText>
                <form method="post" action="/auth/logout" style="display:inline;">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small">
                        Sign out
                    </MudButton>
                </form>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="@DrawerVariant.Mini">
        <MudNavMenu>
            <MudText Typo="Typo.caption" Class="px-4 py-2 mud-text-secondary">Overview</MudText>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">Dashboard</MudNavLink>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Class="px-4 py-2 mud-text-secondary">Work</MudText>
            <MudNavLink Href="/projects" Icon="@Icons.Material.Filled.Folder">Projects</MudNavLink>
            <MudNavLink Href="/tasks" Icon="@Icons.Material.Filled.Assignment">Tasks</MudNavLink>
            <MudNavLink Href="/meetings" Icon="@Icons.Material.Filled.Event">Meetings</MudNavLink>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.caption" Class="px-4 py-2 mud-text-secondary">People</MudText>
            <MudNavLink Href="/employees" Icon="@Icons.Material.Filled.People">Employees</MudNavLink>
            <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Analytics">Reports</MudNavLink>
            <AuthorizeView Roles="Admin">
                <MudDivider Class="my-2" />
                <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.AdminPanelSettings">Admin</MudNavLink>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private readonly MudTheme _theme = new();
}
